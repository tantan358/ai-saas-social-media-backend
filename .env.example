# Database Configuration
# Format: mysql+pymysql://username:password@host:port/database
DATABASE_URL=mysql+pymysql://nervia_user:your_password@localhost/nervia_ai

# JWT Configuration
# Generate a secure secret key: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
# For development: use "*" to allow all origins
# For production: specify exact origins (e.g., "https://yourdomain.com,https://www.yourdomain.com")
CORS_ORIGINS=*

# Stripe Configuration (Optional - leave empty if not using)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Social Media API Configuration (Optional)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# AI Service Configuration (Optional)
AI_API_KEY=
AI_API_URL=https://api.openai.com/v1

# App Configuration
ENVIRONMENT=development
DEBUG=True
